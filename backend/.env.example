# Скопируйте этот файл в .env и подставьте свои значения.

# Строка подключения к БД (async-драйвер).
# PostgreSQL:
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@localhost:5432/monopoly
# Локальная альтернатива (SQLite), если Postgres недоступен:
# DATABASE_URL=sqlite+aiosqlite:///./monopoly.db

# Секрет для подписи JWT преподавателя. Сгенерируйте случайную строку.
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS: адрес фронтенда в dev-режиме
FRONTEND_ORIGIN=http://localhost:5173

# Провайдер генерации вопросов (Фаза 8). Для MVP не требуется.
AI_PROVIDER=none
GIGACHAT_CREDENTIALS=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
